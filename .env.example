# ============================================================
# Video-to-Notes Skill Configuration
# Copy this file to .env and fill in your values
# ============================================================

# Required: ModelScope API key (get from https://modelscope.cn)
MODELSCOPE_API_KEY="your-api-key-here"
MODELSCOPE_API_BASE_URL="https://api-inference.modelscope.cn/v1"

# Primary models
VLM_MODEL=Qwen/Qwen3-VL-8B-Instruct
LLM_MODEL=moonshotai/Kimi-K2.5

# Fallback LLMs (comma-separated, tried in order when primary is rate-limited)
LLM_FALLBACK=Qwen/Qwen3-235B-A22B,Qwen/Qwen3-32B,Qwen/Qwen3-14B

# Fallback VLM (optional, leave empty if no alternative VL model available)
VLM_FALLBACK=

# ASR model: tiny / base / small / medium / large (faster-whisper)
ASR_MODEL=base